# Normalizar finales de linea en el repositorio
* text=auto eol=lf

# Scripts que deben conservar LF para ejecutarse en Linux/macOS
gradlew text eol=lf
*.sh text eol=lf

# Scripts de Windows
gradlew.bat text eol=crlf
*.bat text eol=crlf

# Binarios
*.jar binary
*.apk binary
*.aab binary
*.png binary
*.jpg binary
*.webp binary
